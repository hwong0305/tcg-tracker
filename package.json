{
  "name": "cardtracker-core",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "test": "bun test apps/api packages",
    "jobs:ingest": "bun run packages/jobs/src/ingest-onepiece.ts",
    "jobs:scrape": "bun run packages/jobs/src/scrape-prices.ts",
    "jobs:recompute": "bun run packages/jobs/src/recompute-flags.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.44.6",
    "elysia": "^1.4.16",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "bun-types": "^1.3.0",
    "drizzle-kit": "^0.31.5",
    "jsdom": "^26.1.0",
    "playwright": "^1.55.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
